<?xml version="1.0"?>
<configuration>
  <!--
    Spark sees this file via HADOOP_CONF_DIR=/opt/hadoop-conf (the same
    directory that holds core-site.xml + hdfs-site.xml). When
    spark.sql.catalogImplementation=hive (in spark-defaults.conf),
    Spark uses this URI to register tables in HMS, so Presto can read them.
  -->
  <property>
    <name>hive.metastore.uris</name>
    <value>thrift://hive-metastore:9083</value>
  </property>
</configuration>
